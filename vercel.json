{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/blob/upload",
      "dest": "api/blob/upload.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
